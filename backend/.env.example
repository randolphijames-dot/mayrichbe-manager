# 复制为 .env 并填入真实值

# 应用设置
APP_NAME=Social Manager
DEBUG=false

# 数据库（开发用 SQLite，生产改为 PostgreSQL）
DATABASE_URL=sqlite:///./social_manager.db
# DATABASE_URL=postgresql://user:password@localhost:5432/social_manager

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 文件存储
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500

# AdsPower（本地运行 AdsPower 后使用默认端口）
ADSPOWER_API_URL=http://local.adspower.net:50325
ADSPOWER_API_KEY=

# 比特浏览器（BitBrowser，本地运行后默认端口 54345）
BITBROWSER_API_URL=http://127.0.0.1:54345

# 发布结果通知（可选，填入即可使用）
LINE_NOTIFY_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# YouTube OAuth
YT_CLIENT_ID=your-google-client-id
YT_CLIENT_SECRET=your-google-client-secret
YT_REDIRECT_URI=http://localhost:8000/api/v1/youtube/oauth/callback

# 安全密钥（生产环境请换成随机字符串）
SECRET_KEY=change-me-to-random-string-in-production
